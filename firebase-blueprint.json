{
  "entities": {
    "User": {
      "title": "User",
      "description": "User specific configurations and metadata",
      "type": "object",
      "properties": {
        "geminiApiKey": {
          "type": "string",
          "description": "The user's personal Google Gemini API key"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["geminiApiKey"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message in a chat",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "model"]
        },
        "parts": {
          "type": "array"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["role", "parts", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User settings"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat sessions"
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat session"
    }
  }
}

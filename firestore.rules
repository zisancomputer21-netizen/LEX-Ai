rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['geminiApiKey', 'updatedAt']);

      function isValidUser(data) {
        return data.keys().hasAll(['geminiApiKey', 'updatedAt'])
           && data.geminiApiKey is string && data.geminiApiKey.size() > 0 && data.geminiApiKey.size() < 256
           && data.updatedAt == request.time;
      }

      // --- Chats Subcollection ---
      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChat(incoming());
        allow update: if isOwner(userId) && isValidChat(incoming())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['title']);
        allow delete: if isOwner(userId);

        function isValidChat(data) {
          return data.keys().hasAll(['createdAt'])
             && data.get('title', '') is string
             && data.createdAt == request.time;
        }

        // --- Messages Subcollection ---
        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(incoming());
          
          function isValidMessage(data) {
            return data.keys().hasAll(['role', 'parts', 'createdAt'])
               && data.role in ['user', 'model']
               && data.parts is list
               && data.createdAt == request.time;
          }
        }
      }
    }
  }
}
